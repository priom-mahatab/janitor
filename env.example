# ── LLM Provider Keys ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Janitor Defaults (all overridable via CLI flags) ──────────────────────────
